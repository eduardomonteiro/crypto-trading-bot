# =============================================================
# crypto-trading-bot — Environment Variables Template
# Copie para .env e preencha com seus valores REAIS
# NUNCA commite o arquivo .env no git
# =============================================================

# --- PostgreSQL (banco de configuracoes do bot) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=freqtrade_config
POSTGRES_USER=freqtrade
POSTGRES_PASSWORD=change_me_strong_password_here
DATABASE_URL=postgresql://freqtrade:change_me_strong_password_here@postgres:5432/freqtrade_config

# --- Exchange Binance ---
EXCHANGE_NAME=binance
EXCHANGE_API_KEY=your_binance_api_key_here
EXCHANGE_API_SECRET=your_binance_api_secret_here
# KuCoin tambem exige passphrase:
# EXCHANGE_API_PASSPHRASE=your_kucoin_passphrase

# --- Telegram Notifications ---
TELEGRAM_ENABLED=false
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# --- Freqtrade REST API ---
API_SERVER_ENABLED=true
API_SERVER_USERNAME=freqtrader
API_SERVER_PASSWORD=change_me_api_password_here
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_me_generate_with_python_secrets_token_hex_32
API_WS_TOKEN=change_me_generate_with_python_secrets_token_hex_16

# --- Trading Mode ---
DRY_RUN=true
DRY_RUN_WALLET=3000
MAX_OPEN_TRADES=3
STAKE_CURRENCY=USDT
STAKE_AMOUNT=unlimited
TRADABLE_BALANCE_RATIO=0.90

# --- Risk Management ---
STOPLOSS=-0.05
TRAILING_STOP=true
TRAILING_STOP_POSITIVE=0.015
TRAILING_STOP_POSITIVE_OFFSET=0.03
MAX_DAILY_DRAWDOWN=0.05

# --- Strategy ---
STRATEGY_NAME=SampleStrategy
TIMEFRAME=1h

# --- FreqAI (opcional) ---
FREQAI_ENABLED=false
FREQAI_MODEL=LightGBMRegressor
FREQAI_IDENTIFIER=lgbm-v1
FREQAI_TRAIN_PERIOD_DAYS=90
FREQAI_RETRAIN_HOURS=24

# --- AI Order Validation (opcional) ---
# Chave para o modelo de IA que valida ordens antes de abrir
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# --- Bot Identity ---
BOT_NAME=crypto-bot-prod
INITIAL_STATE=running
