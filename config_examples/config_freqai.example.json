{
    "$schema": "https://schema.freqtrade.io/schema.json",
    "_comment": "Config FreqAI com LightGBM. Parametros de risco conservadores. Treino: 90 dias. Retreino: 24h.",
    "trading_mode": "futures",
    "margin_mode": "isolated",
    "max_open_trades": 3,
    "stake_currency": "USDT",
    "stake_amount": "unlimited",
    "tradable_balance_ratio": 0.90,
    "fiat_display_currency": "USD",
    "dry_run": true,
    "dry_run_wallet": 3000,
    "timeframe": "1h",
    "cancel_open_orders_on_exit": true,
    "stoploss": -0.05,
    "trailing_stop": true,
    "trailing_stop_positive": 0.015,
    "trailing_stop_positive_offset": 0.030,
    "trailing_only_offset_is_reached": true,
    "minimal_roi": {
        "120": 0.0,
        "60": 0.01,
        "30": 0.02,
        "0": 0.04
    },
    "unfilledtimeout": {
        "entry": 5,
        "exit": 15
    },
    "exchange": {
        "name": "binance",
        "key": "",
        "secret": "",
        "ccxt_config": {"enableRateLimit": true},
        "ccxt_async_config": {"enableRateLimit": true},
        "pair_whitelist": [
            "BTC/USDT:USDT",
            "ETH/USDT:USDT",
            "SOL/USDT:USDT",
            "BNB/USDT:USDT"
        ],
        "pair_blacklist": [
            "BNB/.*",
            ".*DOWN/.*",
            ".*UP/.*"
        ]
    },
    "pairlists": [
        {
            "method": "VolumePairList",
            "number_assets": 10,
            "sort_key": "quoteVolume",
            "refresh_period": 1800
        },
        {"method": "AgeFilter", "min_days_listed": 30},
        {"method": "PrecisionFilter"},
        {"method": "SpreadFilter", "max_spread_ratio": 0.003}
    ],
    "freqai": {
        "enabled": true,
        "purge_old_models": 3,
        "train_period_days": 90,
        "backtest_period_days": 30,
        "live_retrain_hours": 24,
        "expiry_hours": 1,
        "identifier": "lgbm-mtf-v1",
        "feature_parameters": {
            "include_timeframes": ["1h", "4h", "1d"],
            "include_corr_pairlist": [
                "BTC/USDT:USDT",
                "ETH/USDT:USDT",
                "BNB/USDT:USDT"
            ],
            "label_period_candles": 24,
            "include_shifted_candles": 3,
            "DI_threshold": 0.9,
            "weight_factor": 0.9,
            "principal_component_analysis": false,
            "use_SVM_to_remove_outliers": true,
            "indicator_periods_candles": [10, 20, 50],
            "plot_feature_importances": 5,
            "noise_standard_deviation": 0.01
        },
        "data_split_parameters": {
            "test_size": 0.15,
            "shuffle": false
        },
        "model_training_parameters": {
            "n_estimators": 1000,
            "learning_rate": 0.05,
            "num_leaves": 31,
            "min_child_samples": 20,
            "feature_fraction": 0.8,
            "bagging_fraction": 0.8,
            "bagging_freq": 5,
            "verbose": -1,
            "n_jobs": -1
        }
    },
    "telegram": {
        "enabled": false,
        "token": "",
        "chat_id": ""
    },
    "api_server": {
        "enabled": true,
        "listen_ip_address": "127.0.0.1",
        "listen_port": 8080,
        "verbosity": "error",
        "jwt_secret_key": "",
        "CORS_origins": ["http://localhost:3000"],
        "username": "freqtrader",
        "password": ""
    },
    "bot_name": "freqai-lgbm-v1",
    "force_entry_enable": false,
    "initial_state": "running",
    "internals": {
        "process_throttle_secs": 5,
        "heartbeat_interval": 60
    }
}
